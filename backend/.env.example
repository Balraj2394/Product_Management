# Database (use DATABASE_URL for cloud, or individual vars for local)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Individual DB vars (used when DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=product_management

# Server
PORT=5000

# Frontend URL (for CORS)
FRONTEND_URL=https://your-app.vercel.app
